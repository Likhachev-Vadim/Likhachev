<Window x:Class="LikhachevStore.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="МАГАЗИН ОБУВИ - Likhachev"
        Height="750" Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="#FFFFFF">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        
        <Border Grid.Row="0" Background="#7FFF00" Padding="15">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="images/Icon.png" Width="50" Height="50" Stretch="Uniform" Margin="0,0,15,0"/>
                    <TextBlock Text="МАГАЗИН ОБУВИ" FontSize="24" FontWeight="Bold" FontFamily="Times New Roman" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel x:Name="pnlUserInfo" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Visibility="Collapsed">
                    <TextBlock x:Name="txtUserName" Foreground="Black" FontSize="14" FontFamily="Times New Roman" Margin="0,0,10,0"/>
                    <TextBlock x:Name="txtUserRole" Foreground="#2C3E50" FontSize="14" FontWeight="Bold" FontFamily="Times New Roman" Margin="0,0,15,0"/>
                    <Button x:Name="btnLogout" Content="Выйти" Click="BtnLogout_Click" Background="#00FA9A" Foreground="Black" Padding="10,5" Cursor="Hand" FontFamily="Times New Roman" FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </Border>

        
        <Grid x:Name="pnlLogin" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Width="400">
            <Border Background="White" CornerRadius="10" Padding="30" BorderBrush="#7FFF00" BorderThickness="2">
                <StackPanel>
                    <TextBlock Text="ВХОД В СИСТЕМУ" FontSize="22" FontWeight="Bold" FontFamily="Times New Roman" Margin="0,0,0,20" HorizontalAlignment="Center"/>
                    <TextBlock Text="Логин" FontFamily="Times New Roman" Margin="0,5,0,0"/>
                    <TextBox x:Name="txtLogin" Margin="0,5,0,15" Padding="10" FontSize="14" FontFamily="Times New Roman"/>
                    <TextBlock Text="Пароль" FontFamily="Times New Roman" Margin="0,5,0,0"/>
                    <PasswordBox x:Name="txtPassword" Margin="0,5,0,15" Padding="10" FontSize="14" FontFamily="Times New Roman"/>
                    <TextBlock x:Name="txtError" Foreground="Red" Margin="0,0,0,10" TextWrapping="Wrap" FontFamily="Times New Roman"/>
                    <Button x:Name="btnLogin" Content="ВОЙТИ" Click="BtnLogin_Click" Background="#00FA9A" Foreground="Black" FontSize="16" FontWeight="Bold" Padding="15" Margin="0,10,0,10" Cursor="Hand" FontFamily="Times New Roman"/>
                    <Button x:Name="btnGuest" Content="ПРОДОЛЖИТЬ КАК ГОСТЬ" Click="BtnGuest_Click" Background="#7FFF00" Foreground="Black" FontSize="14" FontWeight="Bold" Padding="15" Cursor="Hand" FontFamily="Times New Roman"/>
                    <TextBlock Text="admin / admin" FontSize="12" Foreground="Gray" FontFamily="Times New Roman" HorizontalAlignment="Center" Margin="0,15,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        
        <Grid x:Name="pnlProducts" Grid.Row="1" Visibility="Collapsed" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            
            <Border x:Name="pnlSearchFilter" Grid.Row="0" Background="#7FFF00" Padding="10" Margin="0,0,0,10" CornerRadius="8" Visibility="Collapsed">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="txtSearch" Grid.Column="0" Padding="10" FontSize="14" FontFamily="Times New Roman" TextChanged="TxtSearch_TextChanged"/>
                    <TextBlock Grid.Column="1" Text="Категория:" VerticalAlignment="Center" Margin="15,0,5,0" FontFamily="Times New Roman" FontWeight="Bold"/>
                    <ComboBox x:Name="cmbCategory" Grid.Column="2" Width="150" Margin="5,0,15,0" FontFamily="Times New Roman" SelectionChanged="CmbCategory_SelectionChanged"/>
                    <Button x:Name="btnSortAsc" Grid.Column="3" Content="По кол-ву ↑" Click="BtnSortAsc_Click" Margin="5,0" Padding="10,5" Background="#00FA9A" FontFamily="Times New Roman" FontWeight="Bold"/>
                    <Button x:Name="btnSortDesc" Grid.Column="4" Content="По кол-ву ↓" Click="BtnSortDesc_Click" Margin="5,0" Padding="10,5" Background="#00FA9A" FontFamily="Times New Roman" FontWeight="Bold"/>
                    <Button x:Name="btnAddProduct" Grid.Column="5" Content="+ Добавить" Click="BtnAddProduct_Click" Margin="15,0,0,0" Padding="10,5" Background="#00FA9A" FontFamily="Times New Roman" FontWeight="Bold" Visibility="Collapsed"/>
                </Grid>
            </Border>

            
            <DataGrid x:Name="dgvProducts" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True"
                      AlternatingRowBackground="#F9F9F9" FontSize="13" FontFamily="Times New Roman"
                      RowBackground="White" LoadingRow="dgvProducts_LoadingRow">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Фото" Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Image Width="60" Height="60" Stretch="Uniform" HorizontalAlignment="Center" Source="{Binding ImagePath}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" Width="160"/>
                    <DataGridTextColumn Header="Категория" Binding="{Binding Category}" Width="100"/>
                    <DataGridTextColumn Header="Производитель" Binding="{Binding Manufacturer}" Width="110"/>
                    <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat={}{0:F2} руб}" Width="90"/>
                    <DataGridTextColumn Header="Скидка" Binding="{Binding Discount, StringFormat={}{0:F0}%}" Width="70"/>
                    <DataGridTextColumn Header="Итоговая цена" Binding="{Binding FinalPrice, StringFormat={}{0:F2} руб}" Width="110"/>
                    <DataGridTextColumn Header="Кол-во" Binding="{Binding StockQuantity}" Width="80"/>
                    <DataGridTextColumn Header="Ед. изм." Binding="{Binding Unit}" Width="80"/>

                    
                    <DataGridTemplateColumn Header="Действия" Width="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="Изменить" Click="EditButton_Click" Tag="{Binding}" Background="#00FA9A" Padding="8,3" Margin="2" FontFamily="Times New Roman" FontSize="11" Cursor="Hand"/>
                                    <Button Content="Удалить" Click="DeleteButton_Click" Tag="{Binding}" Background="#E74C3C" Foreground="White" Padding="8,3" Margin="2" FontFamily="Times New Roman" FontSize="11" Cursor="Hand"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <Border Grid.Row="2" Background="#7FFF00" Padding="8">
            <TextBlock x:Name="txtStatus" Foreground="Black" FontSize="11" FontFamily="Times New Roman"/>
        </Border>
    </Grid>
</Window>