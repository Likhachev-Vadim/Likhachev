<Window x:Class="LikhachevStore.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="МАГАЗИН ОБУВИ - Likhachev"
        Height="750" Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="#FFFFFF">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        
        <Border Grid.Row="0" Background="#7FFF00" Padding="15">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="images/Icon.png" Width="50" Height="50" Stretch="Uniform" Margin="0,0,15,0"/>
                    <TextBlock Text="МАГАЗИН ОБУВИ" FontSize="24" FontWeight="Bold" FontFamily="Times New Roman" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel x:Name="pnlUserInfo" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Visibility="Collapsed">
                    <TextBlock x:Name="txtUserName" Foreground="Black" FontSize="14" FontFamily="Times New Roman" Margin="0,0,10,0"/>
                    <TextBlock x:Name="txtUserRole" Foreground="#2C3E50" FontSize="14" FontWeight="Bold" FontFamily="Times New Roman" Margin="0,0,15,0"/>
                    <Button x:Name="btnLogout" Content="Выйти" Click="BtnLogout_Click" Background="#00FA9A" Foreground="Black" Padding="10,5" Cursor="Hand" FontFamily="Times New Roman" FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </Border>

        
        <Grid x:Name="pnlLogin" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Width="400">
            <Border Background="White" CornerRadius="10" Padding="30" BorderBrush="#7FFF00" BorderThickness="2">
                <StackPanel>
                    <TextBlock Text="ВХОД В СИСТЕМУ" FontSize="22" FontWeight="Bold" FontFamily="Times New Roman" Margin="0,0,0,20" HorizontalAlignment="Center"/>

                    <TextBlock Text="Логин" FontFamily="Times New Roman" Margin="0,5,0,0"/>
                    <TextBox x:Name="txtLogin" Margin="0,5,0,15" Padding="10" FontSize="14" FontFamily="Times New Roman"/>

                    <TextBlock Text="Пароль" FontFamily="Times New Roman" Margin="0,5,0,0"/>
                    <PasswordBox x:Name="txtPassword" Margin="0,5,0,15" Padding="10" FontSize="14" FontFamily="Times New Roman"/>

                    <TextBlock x:Name="txtError" Foreground="Red" Margin="0,0,0,10" TextWrapping="Wrap" FontFamily="Times New Roman"/>

                    <Button x:Name="btnLogin" Content="ВОЙТИ" Click="BtnLogin_Click" Background="#00FA9A" Foreground="Black" FontSize="16" FontWeight="Bold" Padding="15" Margin="0,10,0,10" Cursor="Hand" FontFamily="Times New Roman"/>

                    <Button x:Name="btnGuest" Content="ПРОДОЛЖИТЬ КАК ГОСТЬ" Click="BtnGuest_Click" Background="#7FFF00" Foreground="Black" FontSize="14" FontWeight="Bold" Padding="15" Cursor="Hand" FontFamily="Times New Roman"/>

                    <TextBlock Text="admin / admin, manager / manager, client / client" FontSize="12" Foreground="Gray" FontFamily="Times New Roman" HorizontalAlignment="Center" Margin="0,15,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        
        <Grid x:Name="pnlProducts" Grid.Row="1" Visibility="Collapsed" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            
            <Border x:Name="pnlSearchFilter" Grid.Row="0" Background="#7FFF00" Padding="10" Margin="0,0,0,10" CornerRadius="8" Visibility="Collapsed">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="txtSearch" Grid.Column="0" Padding="10" FontSize="14" FontFamily="Times New Roman" TextChanged="TxtSearch_TextChanged"/>

                    <TextBlock Grid.Column="1" Text="Поставщик:" VerticalAlignment="Center" Margin="15,0,5,0" FontFamily="Times New Roman" FontWeight="Bold"/>

                    <ComboBox x:Name="cmbSupplier" Grid.Column="2" Width="150" Margin="5,0,15,0" FontFamily="Times New Roman" SelectionChanged="CmbSupplier_SelectionChanged"/>

                    <Button x:Name="btnSortAsc" Grid.Column="3" Content="По кол-ву (возр)" Click="BtnSortAsc_Click" Margin="5,0" Padding="10,5" Background="#00FA9A" FontFamily="Times New Roman" FontWeight="Bold"/>

                    <Button x:Name="btnSortDesc" Grid.Column="4" Content="По кол-ву (убыв)" Click="BtnSortDesc_Click" Margin="5,0" Padding="10,5" Background="#00FA9A" FontFamily="Times New Roman" FontWeight="Bold"/>

                    <Button x:Name="btnAddProduct" Grid.Column="5" Content="+ Добавить товар" Click="BtnAddProduct_Click" Margin="15,0,0,0" Padding="10,5" Background="#00FA9A" FontFamily="Times New Roman" FontWeight="Bold" Visibility="Collapsed"/>
                </Grid>
            </Border>

            
            <Border x:Name="pnlEditForm" Grid.Row="1" Background="White" Padding="15" Margin="0,0,0,10" CornerRadius="8" BorderBrush="#7FFF00" BorderThickness="2" Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Фото:" FontFamily="Times New Roman" FontSize="14" VerticalAlignment="Center" Margin="5"/>
                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="5">
                        <Image x:Name="imgEditPhoto" Width="60" Height="60" Stretch="Uniform" Margin="0,0,10,0"/>
                        <Button x:Name="btnSelectPhoto" Content="Выбрать фото" Click="BtnSelectPhoto_Click" Background="#00FA9A" Padding="10,5" FontFamily="Times New Roman"/>
                    </StackPanel>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Наименование:" FontFamily="Times New Roman" FontSize="14" VerticalAlignment="Center" Margin="5"/>
                    <TextBox x:Name="txtEditName" Grid.Row="1" Grid.Column="1" Margin="5" Padding="5" FontFamily="Times New Roman" FontSize="14"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Категория:" FontFamily="Times New Roman" FontSize="14" VerticalAlignment="Center" Margin="5"/>
                    <ComboBox x:Name="cmbEditCategory" Grid.Row="2" Grid.Column="1" Margin="5" Padding="5" FontFamily="Times New Roman"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Производитель:" FontFamily="Times New Roman" FontSize="14" VerticalAlignment="Center" Margin="5"/>
                    <ComboBox x:Name="cmbEditManufacturer" Grid.Row="3" Grid.Column="1" Margin="5" Padding="5" FontFamily="Times New Roman"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Поставщик:" FontFamily="Times New Roman" FontSize="14" VerticalAlignment="Center" Margin="5"/>
                    <ComboBox x:Name="cmbEditSupplier" Grid.Row="4" Grid.Column="1" Margin="5" Padding="5" FontFamily="Times New Roman"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Цена:" FontFamily="Times New Roman" FontSize="14" VerticalAlignment="Center" Margin="5"/>
                    <TextBox x:Name="txtEditPrice" Grid.Row="5" Grid.Column="1" Margin="5" Padding="5" FontFamily="Times New Roman" FontSize="14"/>

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Скидка (%):" FontFamily="Times New Roman" FontSize="14" VerticalAlignment="Center" Margin="5"/>
                    <TextBox x:Name="txtEditDiscount" Grid.Row="6" Grid.Column="1" Margin="5" Padding="5" FontFamily="Times New Roman" FontSize="14"/>

                    <TextBlock Grid.Row="7" Grid.Column="0" Text="Количество:" FontFamily="Times New Roman" FontSize="14" VerticalAlignment="Center" Margin="5"/>
                    <TextBox x:Name="txtEditQuantity" Grid.Row="7" Grid.Column="1" Margin="5" Padding="5" FontFamily="Times New Roman" FontSize="14"/>

                    <TextBlock Grid.Row="8" Grid.Column="0" Text="Ед. изм.:" FontFamily="Times New Roman" FontSize="14" VerticalAlignment="Center" Margin="5"/>
                    <ComboBox x:Name="cmbEditUnit" Grid.Row="8" Grid.Column="1" Margin="5" Padding="5" FontFamily="Times New Roman"/>

                    <StackPanel Grid.Row="9" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
                        <Button x:Name="btnSaveProduct" Content="Сохранить" Click="BtnSaveProduct_Click" Background="#00FA9A" Padding="20,10" Margin="10" FontFamily="Times New Roman" FontWeight="Bold"/>
                        <Button x:Name="btnDeleteProduct" Content="Удалить" Click="BtnDeleteProduct_Click" Background="#E74C3C" Foreground="White" Padding="20,10" Margin="10" FontFamily="Times New Roman" FontWeight="Bold" Visibility="Collapsed"/>
                        <Button x:Name="btnCancelEdit" Content="Отмена" Click="BtnCancelEdit_Click" Background="#7FFF00" Padding="20,10" Margin="10" FontFamily="Times New Roman" FontWeight="Bold"/>
                    </StackPanel>

                    <TextBlock x:Name="txtEditError" Grid.Row="10" Grid.ColumnSpan="2" Foreground="Red" Margin="10" TextWrapping="Wrap" FontFamily="Times New Roman"/>
                </Grid>
            </Border>

            
            <DataGrid x:Name="dgvProducts" Grid.Row="3" 
                      AutoGenerateColumns="False" 
                      IsReadOnly="True"
                      AlternatingRowBackground="#F9F9F9" 
                      FontSize="13" 
                      FontFamily="Times New Roman"
                      RowBackground="White"
                      LoadingRow="dgvProducts_LoadingRow"
                      MouseDoubleClick="dgvProducts_MouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Фото" Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Image Width="60" Height="60" Stretch="Uniform" HorizontalAlignment="Center">
                                    <Image.Source>
                                        <Binding Path="ImagePath"/>
                                    </Image.Source>
                                </Image>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" Width="160"/>
                    <DataGridTextColumn Header="Категория" Binding="{Binding Category}" Width="100"/>
                    <DataGridTextColumn Header="Производитель" Binding="{Binding Manufacturer}" Width="110"/>
                    <DataGridTextColumn Header="Поставщик" Binding="{Binding Supplier}" Width="120"/>
                    <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat={}{0:F2} руб}" Width="90"/>
                    <DataGridTextColumn Header="Скидка" Binding="{Binding Discount, StringFormat={}{0:F0}%}" Width="70"/>
                    <DataGridTextColumn Header="Итоговая цена" Binding="{Binding FinalPrice, StringFormat={}{0:F2} руб}" Width="110"/>
                    <DataGridTextColumn Header="Кол-во" Binding="{Binding StockQuantity}" Width="80"/>
                    <DataGridTextColumn Header="Ед. изм." Binding="{Binding Unit}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        
        <Border Grid.Row="2" Background="#7FFF00" Padding="8">
            <TextBlock x:Name="txtStatus" Foreground="Black" FontSize="11" FontFamily="Times New Roman"/>
        </Border>
    </Grid>
</Window>